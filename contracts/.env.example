# ============================================
# avax-aqua0 — Contracts Environment
# ============================================
# cp .env.example .env

# ── Deployer wallet ─────────────────────────
# MUST include the 0x prefix — forge's vm.envUint parses this as a hex uint256.
# Get test AVAX at https://faucet.avax.network/
DEPLOYER_PRIVATE_KEY=0x

# ── RPC Endpoints ───────────────────────────
# Avalanche's official Fuji RPC (api.avax-test.network) only returns
# FINALIZED state and rejects queries against pending blocks with
# "cannot query unfinalized data" — fatal for forge scripts that read
# the deployer's nonce right after a transfer. publicnode serves
# unfinalized state and works out of the box. Switch back to the
# official endpoint only if you need a paid quota.
FUJI_RPC_URL=https://avalanche-fuji-c-chain.publicnode.com
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# ── Block Explorer ──────────────────────────
# Snowtrace via Routescan (free key at routescan.io)
SNOWTRACE_API_KEY=
